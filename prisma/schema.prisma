generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum KpiType {
  UPWARD
  DOWNWARD_GENERAL
  DOWNWARD_DEPARTMENT

  @@map("kpi_type")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  actorId    Int?      @map("actor_id")
  action     String    @db.VarChar(100)
  entityType String    @map("entity_type") @db.VarChar(50)
  entityId   Int       @map("entity_id")
  beforeData Json?     @map("before_data")
  afterData  Json?     @map("after_data")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  actor Member? @relation("AuditLogsActor", fields: [actorId], references: [id])

  @@map("audit_logs")
}

model DepartEvaluation {
  id          Int       @id @default(autoincrement())
  evaluatorId Int?      @map("evaluator_id")
  periodId    Int?      @map("period_id")
  submittedAt DateTime? @map("submitted_at") @db.Timestamptz(6)
  divisionId  Int?      @map("divisions_id")

  evaluator Member?           @relation("DepartEvaluationsEvaluator", fields: [evaluatorId], references: [id])
  period    EvaluationPeriod? @relation(fields: [periodId], references: [id])
  division  Division?         @relation(fields: [divisionId], references: [id])
  scores    DepartScore[]

  @@map("depart_evaluations")
}

model DepartKpi {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  indicatorName String?  @map("indicator_name") @db.Text
  definition    String?  @db.Text
  explanation   String?  @db.Text
  weight        Int?
  maxScore      Int?     @map("max_score")

  scores DepartScore[]

  @@map("depart_kpis")
}

model DepartScore {
  id                 Int       @id @default(autoincrement())
  departEvaluationId Int?      @map("depart_evaluation_id")
  departKpiId        Int?      @map("depart_kpi_id")
  score              Int?
  notes              String?   @db.Text
  createdAt          DateTime? @map("created_at") @db.Timestamptz(6)

  departEvaluation DepartEvaluation? @relation(fields: [departEvaluationId], references: [id])
  departKpi        DepartKpi?        @relation(fields: [departKpiId], references: [id])

  @@map("depart_scores")
}

model Division {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  members           Member[]
  subDivisions      SubDivision[]
  kpis              Kpi[]
  departEvaluations DepartEvaluation[]

  @@map("divisions")
}

model EvaluationPeriod {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  quartal   Int
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  evaluations       Evaluation[]
  departEvaluations DepartEvaluation[]

  @@index([isActive, createdAt])
  @@map("evaluation_periods")
}

model EvaluationPolicy {
  id              Int       @id @default(autoincrement())
  evaluatorRoleId Int       @map("evaluator_role_id")
  evaluateeRoleId Int       @map("evaluatee_role_id")
  divisionScope   String    @map("division_scope") @db.VarChar(30)
  priority        Int?      @default(1)
  isActive        Boolean?  @default(true) @map("is_active")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  evaluatorRole Role @relation("EvaluationPoliciesEvaluatorRole", fields: [evaluatorRoleId], references: [id])
  evaluateeRole Role @relation("EvaluationPoliciesEvaluateeRole", fields: [evaluateeRoleId], references: [id])

  @@index([evaluatorRoleId, isActive])
  @@index([evaluatorRoleId, evaluateeRoleId, isActive])
  @@index([priority])
  @@map("evaluation_policies")
}

model Evaluation {
  id          Int       @id @default(autoincrement())
  evaluatorId Int       @map("evaluator_id")
  evaluateeId Int       @map("evaluatee_id")
  periodId    Int?      @map("period_id")
  submittedAt DateTime? @map("submitted_at") @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  evaluator Member            @relation("EvaluationsEvaluator", fields: [evaluatorId], references: [id])
  evaluatee Member            @relation("EvaluationsEvaluatee", fields: [evaluateeId], references: [id])
  period    EvaluationPeriod? @relation(fields: [periodId], references: [id])
  scores    EvaluationScore[]

  @@unique([evaluatorId, evaluateeId, periodId])
  @@index([evaluatorId])
  @@index([evaluateeId])
  @@index([periodId])
  @@index([evaluatorId, periodId])
  @@index([evaluateeId, periodId])
  @@index([createdAt])
  @@map("evaluations")
}

model EvaluationScore {
  id           Int      @id @default(autoincrement())
  evaluationId Int      @map("evaluation_id")
  kpiId        Int      @map("kpi_id")
  score        Int
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  kpi        Kpi        @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([kpiId])
  @@index([evaluationId, kpiId])
  @@map("evaluation_scores")
}

model Kpi {
  id            Int       @id @default(autoincrement())
  indicatorName String    @map("indicator_name") @db.VarChar(150)
  definition    String    @db.Text
  type          KpiType
  divisionId    Int?      @map("division_id")
  weight        Int?      @default(1)
  maxScore      Int?      @default(6) @map("max_score")
  version       Int?      @default(1)
  isActive      Boolean?  @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  explanation   String?   @db.Text

  division         Division?         @relation(fields: [divisionId], references: [id])
  evaluationScores EvaluationScore[]

  @@index([divisionId, isActive])
  @@index([isActive])
  @@map("kpis")
}

model Member {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password      String    @db.VarChar(255)
  divisionId    Int?      @map("division_id")
  subDivisionId Int?      @map("sub_division_id")
  rememberToken String?   @map("remember_token") @db.VarChar(100)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  roleId        Int?      @map("role_id")

  division    Division?    @relation(fields: [divisionId], references: [id])
  subDivision SubDivision? @relation(fields: [subDivisionId], references: [id])
  role        Role?        @relation(fields: [roleId], references: [id])

  auditLogs                  AuditLog[]         @relation("AuditLogsActor")
  evaluationsAsEvaluator     Evaluation[]       @relation("EvaluationsEvaluator")
  evaluationsAsEvaluatee     Evaluation[]       @relation("EvaluationsEvaluatee")
  departEvaluationsEvaluator DepartEvaluation[] @relation("DepartEvaluationsEvaluator")

  @@index([roleId])
  @@index([divisionId])
  @@index([subDivisionId])
  @@index([roleId, divisionId])
  @@index([roleId, subDivisionId])
  @@map("members")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  members                       Member[]
  evaluationPoliciesAsEvaluator EvaluationPolicy[] @relation("EvaluationPoliciesEvaluatorRole")
  evaluationPoliciesAsEvaluatee EvaluationPolicy[] @relation("EvaluationPoliciesEvaluateeRole")

  @@map("roles")
}

model SubDivision {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(100)
  divisionId Int    @map("division_id")

  division Division @relation(fields: [divisionId], references: [id])
  members  Member[]

  @@map("sub_divisions")
}